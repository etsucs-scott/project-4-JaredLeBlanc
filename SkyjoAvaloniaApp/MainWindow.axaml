<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:metadata="using:Avalonia.Metadata"
        xmlns:vm="clr-namespace:SkyjoAvaloniaApp.ViewModels"
        x:Class="SkyjoAvaloniaApp.MainWindow"
        x:DataType="vm:GameViewModel"
        Width="800" Height="600"
        Title="Skyjo">
    <Design.DataContext>
        <vm:GameViewModel/>
    </Design.DataContext>
    <StackPanel Margin="10" Spacing="10">


        <StackPanel Orientation="Horizontal"
            HorizontalAlignment="Center"
            Spacing="40">

                <!-- Drawn Card -->
                <StackPanel>
                    <TextBlock Text="Drawn Card" HorizontalAlignment="Center"/>
                    <Border Width="50" Height="70"
                            Background="LightGray"
                            CornerRadius="5">
                        <TextBlock Text="{Binding DrawnCardValue}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="20"/>
                    </Border>

                    <!-- Discard button -->
                    <Button Content="Discard"
                            HorizontalAlignment="Center"
                            FontSize="14"
                            Width="70"
                            Height="30"
                            HorizontalContentAlignment="Center"
                            Command="{Binding DiscardCardCommand}"/>
                </StackPanel>

                <!-- Draw Pile -->
                <StackPanel>
                    <TextBlock Text="Draw Pile" HorizontalAlignment="Center"/>
                    <Button Content="?" FontSize="20" 
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Command="{Binding DrawFromDeckCommand}"
                            Width="50" Height="70"/>
                </StackPanel>

                <!-- Discard Pile -->
                <StackPanel>
                    <TextBlock Text="Discard" HorizontalAlignment="Center"/>
                    <Button Content="{Binding DiscardTopValue}"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Command="{Binding TakeDiscardCommand}"
                            Width="50" Height="70"/>
                </StackPanel>
        </StackPanel>

        <!-- Current Player -->
        <TextBlock Text="{Binding CurrentPlayerName}"
                   FontSize="20"
                   HorizontalAlignment="Center"/>
        <!-- Game Board -->
        <ItemsControl ItemsSource="{Binding Board}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="3" Columns="4"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:CardViewModel"> 
                    <Button Content="{Binding DisplayValue}"
                        Command="{Binding FlipCommand}"
                        CommandParameter="{Binding}"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        HorizontalAlignment="Center"
                        Width="40" Height="60"/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
            <Button Content="End Turn" Click="EndTurn_Click"/>
            <Button Content="Save" Click="Save_Click"/>
            <Button Content="Load" Click="Load_Click"/>
        </StackPanel>

        <TextBlock Text="{Binding StatusMessage}"
           Foreground="Red"
           HorizontalAlignment="Center"/>

        <StackPanel HorizontalAlignment="Center" Spacing="5">

            <!-- Game Over Title -->
            <TextBlock Text="GAME OVER"
                        FontSize="24"
                        Foreground="Red"
                        HorizontalAlignment="Center"
                        IsVisible="{Binding IsGameOver}"/>

            <!-- Winner -->
            <TextBlock Text="{Binding WinnerText}"
                        FontSize="18"
                        Foreground="Green"
                        HorizontalAlignment="Center"
                        IsVisible="{Binding IsGameOver}"/>

            <!-- Scores -->
            <TextBlock Text="{Binding ScoreText}"
                        HorizontalAlignment="Center"
                        IsVisible="{Binding IsGameOver}"/>

        </StackPanel>

    </StackPanel>

</Window>